# Copy to .env on the server (never commit .env).
# VPS: upload .env to the project root (same level as app/ and public/).
# Domain: https://edudropguard.com — document root must be public/

# --- Environment ---
# local | production
DROPGUARD_ENV=production

# URL path prefix. Leave EMPTY when document root is public/ (VPS or edudropguard.com root).
# Only set if the app lives in a subfolder, e.g. DROPGUARD_BASE_PATH=/subdir
DROPGUARD_BASE_PATH=

# Redirect HTTP to HTTPS (enable after certbot / SSL is working)
DROPGUARD_FORCE_HTTPS=1

# Show PHP errors in the browser (0 on production)
APP_DISPLAY_ERRORS=0

# Detailed /health output (0 on production)
DROPGUARD_HEALTH_VERBOSE=0

APP_NAME=Drop Guard

# --- MySQL (Hostinger hPanel → Databases) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u123456789_dropguard
DB_USER=u123456789_dropguard
DB_PASS=your_secure_password_here
DB_CHARSET=utf8mb4

# Optional: field-level encryption for notes/audit JSON (generate a long random secret)
# DROPGUARD_DB_FIELD_KEY=

# --- Sessions ---
SESSION_NAME=dropguard_session
# SESSION_SAVE_PATH=/var/www/edudropguard/storage/sessions

# --- Machine learning (optional) ---
# Shared hosting often blocks proc_open; leave ML_PYTHON empty to use PHP fallback.
# ML_PYTHON=python3
# ML_PREDICT_SCRIPT=
